	author = {Mandelli, Stefano and Merlo, Marco and Colombo, Emanuela},
	month = apr,
	year = {2016},
	pages = {130--142},
	file = {Full Text:/home/claudia/Zotero/storage/Y3KWKVWD/Mandelli et al. - 2016 - Novel procedure to formulate load profiles for off.pdf:application/pdf},
}

